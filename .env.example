# Nourah environment variables. Copy to .env and fill in. Never commit .env.
# All client-readable keys must be prefixed with EXPO_PUBLIC_.

# Supabase (database, auth, storage)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Face scan service. Default is 'mock' so the Perfect Corp 1,000-scan/month free tier
# is never spent during development or self-testing. Switch to 'live' only when you are
# ready to hit the real API in a beta/production build.
#
#   mock        — returns a healthy returning-user scan (score 78, two GCC flags).
#   mock-empty  — returns null, simulating a brand-new user who has never scanned.
#   mock-stale  — returns a 12-day-old scan, exercising the stale-scan UI state.
#   live        — calls the real Perfect Corp SDK (not implemented yet).
EXPO_PUBLIC_SCAN_MODE=mock

# Perfect Corp Beauty Tech API. Only required when EXPO_PUBLIC_SCAN_MODE=live.
EXPO_PUBLIC_PERFECT_CORP_KEY=

# Google AI Studio (Gemini Flash). Used for routine recommendation generation.
EXPO_PUBLIC_GEMINI_KEY=

# RevenueCat subscription keys. Required for paywall and premium gating.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
