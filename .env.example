# Nourah environment variables. Copy to .env and fill in. Never commit .env.
# All client-readable keys must be prefixed with EXPO_PUBLIC_.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (database, auth, storage, edge functions)
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Face scan mode
# Default 'mock' so the Perfect Corp 1,000-scan/month free tier is never spent
# during development or self-testing.
#
#   mock        — returns a healthy returning-user scan (score 78, two GCC flags).
#   mock-empty  — returns null, simulating a brand-new user who has never scanned.
#   mock-stale  — returns a 12-day-old scan, exercising the stale-scan UI state.
#   live        — reads from Supabase + calls the scan-analyze edge function.
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SCAN_MODE=mock

# RevenueCat client SDK keys. Configure the SDK to pass the Supabase user_id as
# `appUserId` so the revenuecat-webhook can attribute events.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Supabase edge function secrets (set via `supabase secrets set NAME=value`).
# These are NEVER prefixed with EXPO_PUBLIC_ — they live server-side only.
#
#   PERFECT_CORP_KEY               Perfect Corp Beauty Tech API key (Module 3).
#   GEMINI_KEY                     Google AI Studio key (Module 4 — routines).
#   REVENUECAT_WEBHOOK_SECRET      Shared secret echoed in RevenueCat dashboard
#                                  Authorization header (Module 6).
#   OPEN_FOOD_FACTS_USER_AGENT     User-Agent string OFF requires for API calls.
#
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the Supabase Edge runtime — do NOT set them yourself.
# ─────────────────────────────────────────────────────────────────────────────
